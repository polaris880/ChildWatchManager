<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 每日时长设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="每日时长限制（分钟）"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="工作日:"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/et_daily_workday"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="120"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="周末:"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/et_daily_weekend"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="180"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="节假日:"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/et_daily_holiday"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="180"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />

        </LinearLayout>

        <!-- 单次时长设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="单次连续观看限制（分钟）"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/et_single_limit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="30"
            android:textSize="16sp"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 间隔时长设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="间隔休息设置（分钟）"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="观看间隔:"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/et_interval_watch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="30"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="休息时长:"
                android:textSize="16sp"
                android:textColor="@color/text_secondary" />

            <EditText
                android:id="@+id/et_interval_rest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:hint="5"
                android:textSize="16sp"
                android:background="@drawable/edit_text_background"
                android:padding="8dp" />

        </LinearLayout>

        <!-- 系统设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统设置"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <Switch
            android:id="@+id/switch_auto_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="开机自启动"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp"
            android:checked="true" />

        <Switch
            android:id="@+id/switch_monitoring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="启用监控"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp"
            android:checked="true" />

        <!-- 密码管理 -->
        <Button
            android:id="@+id/btn_change_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="修改密码"
            android:textSize="16sp"
            android:backgroundTint="@color/secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- 保存按钮 -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="保存设置"
            android:textSize="18sp"
            android:backgroundTint="@color/primary"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
