<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 观看报告"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- 今日统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="今日统计"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="总观看时长:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_today_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1小时30分钟"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="观看次数:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_today_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3次"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="休息次数:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_today_rest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2次"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </LinearLayout>

        <!-- 本周统计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="本周统计"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="周总时长:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_week_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8小时15分钟"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="日均时长:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_week_average"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1小时10分钟"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="奖励使用:"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_week_reward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="45分钟"
                    android:textSize="18sp"
                    android:textColor="@color/accent" />

            </LinearLayout>

        </LinearLayout>

        <!-- 习惯评估 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="习惯评估"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_evaluation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👍 观看习惯良好，继续保持！"
                android:textSize="20sp"
                android:textColor="@color/accent" />

            <TextView
                android:id="@+id/tv_suggestion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="建议适当增加户外活动时间"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- 返回按钮 -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="返回主界面"
            android:textSize="22sp"
            android:backgroundTint="@color/primary"
            android:focusable="true" />

    </LinearLayout>

</ScrollView>
