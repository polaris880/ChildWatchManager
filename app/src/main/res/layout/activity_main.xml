<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/background"
    android:gravity="center">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="儿童锁"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- 状态显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="32dp"
        android:layout_marginBottom="48dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● 监控中"
            android:textSize="24sp"
            android:textColor="@color/accent"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_today_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="今日已观看: 00:00:00"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tv_session_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="当前会话: 00:00:00"
            android:textSize="22sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_remaining_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="剩余时间: 00:00:00"
            android:textSize="24sp"
            android:textColor="@color/primary" />

    </LinearLayout>

    <!-- 操作按钮区域 - 遥控器友好设计 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="⚙ 设置"
            android:textSize="24sp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="@color/primary"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/btn_start_stop" />

        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:text="⏹ 停止监控"
            android:textSize="24sp"
            android:layout_marginStart="16dp"
            android:backgroundTint="@color/accent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusLeft="@id/btn_settings" />

    </LinearLayout>

    <!-- 底部提示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="使用遥控器方向键导航，确认键选择"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="32dp" />

</LinearLayout>
