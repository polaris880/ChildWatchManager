<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="设置家长密码"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- 说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请设置6位数字密码"
        android:textSize="18sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- 密码位数显示 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <!-- 第1位 -->
        <TextView
            android:id="@+id/tv_digit_1"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <!-- 第2位 -->
        <TextView
            android:id="@+id/tv_digit_2"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <!-- 第3位 -->
        <TextView
            android:id="@+id/tv_digit_3"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <!-- 第4位 -->
        <TextView
            android:id="@+id/tv_digit_4"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <!-- 第5位 -->
        <TextView
            android:id="@+id/tv_digit_5"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:layout_marginEnd="8dp"
            android:focusable="true" />

        <!-- 第6位 -->
        <TextView
            android:id="@+id/tv_digit_6"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:text="-"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background"
            android:focusable="true" />

    </LinearLayout>

    <!-- 数字选择按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <!-- 上方按钮 - 增加数字 -->
        <Button
            android:id="@+id/btn_digit_up"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="▲ 增加数字"
            android:textSize="20sp"
            android:backgroundTint="@color/primary"
            android:focusable="true"
            android:layout_marginBottom="16dp" />

        <!-- 数字显示 -->
        <TextView
            android:id="@+id/tv_current_digit"
            android:layout_width="100dp"
            android:layout_height="80dp"
            android:text="0"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:background="@drawable/digit_background_large"
            android:focusable="true" />

        <!-- 下方按钮 - 减少数字 -->
        <Button
            android:id="@+id/btn_digit_down"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="▼ 减少数字"
            android:textSize="20sp"
            android:backgroundTint="@color/primary"
            android:focusable="true"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_confirm_digit"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:text="确认该位"
            android:textSize="20sp"
            android:backgroundTint="@color/accent"
            android:layout_marginEnd="12dp"
            android:focusable="true" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_weight="1"
            android:text="清除重置"
            android:textSize="20sp"
            android:backgroundTint="@color/secondary"
            android:layout_marginStart="12dp"
            android:focusable="true" />

    </LinearLayout>

    <!-- 提示 -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="请设置第1位密码"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="24dp" />

</LinearLayout>
